{
  "name": "my-hifi-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "seed": "tsx scripts/seed-samples.ts",
    "seed:dry": "cross-env DRY_RUN=1 tsx scripts/seed-samples.ts",
    "lint": "oxlint src/ --ignore-pattern \"**/*.astro\"",
    "lint:fix": "oxlint --fix src/ --ignore-pattern \"**/*.astro\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.1.10",
    "fuse.js": "^7.3.0",
    "marked": "^17.0.4",
    "motion": "^12.38.0",
    "pocketbase": "^0.26.8",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^7.0.3",
    "oxlint": "^1.62.0",
    "tsx": "^4.19.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "vite": "^7"
  }
