# ─── PocketBase 连接（运行时 + seed 脚本共用） ───
# 公开数据库地址，前端 SSR 与 seed 都会访问
PB_URL=https://db.91917788.xyz

# ─── seed 脚本专用（仅 npm run seed 用，不要塞进容器/CI 公开变量） ───
# PB 管理员账号，用于一键导入 samples/*.md
# 用法： PB_EMAIL=admin@example.com PB_PASSWORD=xxx npm run seed
PB_EMAIL=
PB_PASSWORD=

# 1 = 只解析 samples，不写库（验证 frontmatter / 网络）
DRY_RUN=

# 1 = slug 已存在时覆盖更新（默认跳过）
FORCE=

# ─── 可选：Analytics（留空即不启用） ───
PUBLIC_ANALYTICS_PROVIDER=
PUBLIC_ANALYTICS_SITE_ID=
PUBLIC_ANALYTICS_SCRIPT_URL=

# ─── 可选：Giscus 评论（留空即不启用） ───
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# ─── 可选：邮件订阅（仅服务端使用，不要暴露到 PUBLIC_*） ───
SUBSCRIBE_PROVIDER=
SUBSCRIBE_API_KEY=
SUBSCRIBE_LIST_ID=
