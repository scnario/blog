---
/**
 * 主 Layout — 全站统一框架
 *
 * 改造（P-Nav）：
 * - 顶部 TopNav 替代原本零散的导航
 * - aside 改为条件渲染：showSidebar / showToc 由页面 props 控制
 * - settings 通过 src/lib/queries.ts 取，带 5 分钟缓存与字段缺失回退
 * - ThemeSwitcher 始终浮动在右下角
 */
import '../styles/global.css';
import HeroHeader from '../components/HeroHeader.astro';
import ProfileCard from '../components/ProfileCard.astro';
import TocPanel from '../components/TocPanel.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import TopNav from '../components/TopNav.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import { getSettings } from '../lib/queries';
import { resolveTheme, type ThemeSlug } from '../lib/theme';

interface Props {
  title?: string;
  frontmatter?: any;
  headings?: any[];
  /** 默认 true，控制台 / 全屏工具页传 false */
  showSidebar?: boolean;
  /** 仅在文章/笔记详情页传 true（且 headings 非空） */
  showToc?: boolean;
}

const {
  title,
  frontmatter,
  headings = [],
  showSidebar = true,
  showToc: showTocProp,
} = Astro.props as Props;

const pageTitle = title || frontmatter?.title || '数字花园';
const toc = headings.filter((h: any) => h.depth <= 3);
const isMarkdown = !!frontmatter;
const showToc = showTocProp ?? toc.length > 0;

const settings = await getSettings();

// cookie 优先，其次 PB settings.active_theme，最后 default
const cookieTheme = Astro.cookies.get('site_theme')?.value;
const activeTheme: ThemeSlug = resolveTheme({
  cookieValue: cookieTheme,
  pbActiveTheme: settings.active_theme,
});

// 主题色：cookie/settings 已有 theme_color 兼容字段
const themeColor = settings.theme_color || '#6B5BFF';
const glassOpacity = settings.glass_opacity;
const glassBlur = settings.glass_blur;
const tocTextBlur = settings.toc_text_blur;
const showParticles = settings.particles_enabled ? 'block' : 'none';

const bgUrl = settings.bg_image
  ? `url('${settings.bg_image}')`
  : 'none';
const avatarMain = settings.avatar_main ? `url('${settings.avatar_main}')` : 'none';
const avatarSub = settings.avatar_sub ? `url('${settings.avatar_sub}')` : 'none';

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN" data-theme={activeTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{pageTitle}</title>

    <style is:global define:vars={{
      themeColor,
      glassOpacity,
      glassBlur,
      tocTextBlur,
      showParticles,
      bgUrl,
      avatarMain,
      avatarSub
    }}>
      :root {
        --text-accent: var(--themeColor);
        --glass-opacity: var(--glassOpacity);
        --glass-bg: rgba(255, 255, 255, var(--glassOpacity));
        --glass-blur: calc(var(--glassBlur) * 1px);
        --toc-text-blur: calc(var(--tocTextBlur) * 1px);
        --show-particles: var(--showParticles);
        --bg-image: var(--bgUrl);
        --avatar-main: var(--avatarMain);
        --avatar-sub: var(--avatarSub);
      }

      /* Bento 浅色基底 — 让现有页面自然适配 */
      body {
        background: #FAFAF7;
        color: #1A1A1F;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>

  <body class="antialiased min-h-screen">
    <TopNav pathname={pathname} brand={settings.nickname || '数字花园'} />

    <div class="page-shell">
      <main class="page-main">
        {isMarkdown && <HeroHeader title={pageTitle} />}
        {isMarkdown ? (
          <article class="hifi-card">
            <slot />
          </article>
        ) : (
          <slot />
        )}
      </main>

      {showSidebar && (
        <aside class="page-aside">
          <ProfileCard />
          {showToc && <TocPanel toc={toc} />}
        </aside>
      )}
    </div>

    <MusicPlayer />
    <ThemeSwitcher active={activeTheme} basePath="/" />

    <style>
      .page-shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 24px 96px;
        display: flex;
        gap: 32px;
        align-items: flex-start;
      }
      .page-main { flex: 1; min-width: 0; }
      .page-aside {
        width: 288px;
        flex-shrink: 0;
        display: flex; flex-direction: column; gap: 24px;
        position: sticky;
        top: 80px;
      }
      @media (max-width: 1024px) {
        .page-aside { display: none; }
      }
      @media (max-width: 640px) {
        .page-shell { padding: 20px 16px 80px; }
      }
    </style>

    <script>
      // 代码块高亮 — 保留原逻辑
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('pre').forEach(pre => {
          if (pre.parentElement?.classList.contains('code-body')) return;
          const lang = pre.getAttribute('data-language') || 'BASH';
          const wrapper = document.createElement('div'); wrapper.className = 'code-wrapper';
          const header = document.createElement('div'); header.className = 'code-header';
          header.innerHTML = `<div class="code-lang"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg>${lang.toUpperCase()}</div><button class="copy-btn"><svg viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path></svg><span>Copy</span></button>`;
          const body = document.createElement('div'); body.className = 'code-body';
          pre.parentNode?.insertBefore(wrapper, pre); wrapper.appendChild(header); wrapper.appendChild(body); body.appendChild(pre);
          const copyBtn = header.querySelector('.copy-btn');
          copyBtn?.addEventListener('click', () => {
            navigator.clipboard.writeText(pre.textContent || '').then(() => {
              copyBtn.classList.add('copied');
              copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"></path></svg><span>Copied!</span>';
              setTimeout(() => { copyBtn.classList.remove('copied'); copyBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path></svg><span>Copy</span>'; }, 2000);
            });
          });
        });
      });
    </script>
  </body>
</html>
