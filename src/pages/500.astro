---
import Layout from '../layouts/Layout.astro';
---

<Layout title="500 · 服务暂时不可用" showSidebar={false}>
  <div class="server-error">
    <div class="code">500</div>
    <h1>服务暂时卡住了</h1>
    <p class="muted">可能是数据库或服务端短暂不可用。稍后刷新，或者先回首页继续浏览。</p>
    <div class="actions">
      <a href="/" class="btn-primary">← 回到首页</a>
      <a href="/articles" class="btn-secondary">看博客</a>
    </div>
  </div>

  <style>
    .server-error {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
      text-align: center;
      padding: 48px 24px;
    }
    .code {
      font-family: var(--font-mono);
      font-size: clamp(80px, 15vw, 140px);
      font-weight: 900;
      color: var(--surface-fg);
      line-height: 1;
      letter-spacing: -0.04em;
    }
    h1 {
      font-family: var(--font-display);
      font-size: clamp(22px, 3.5vw, 32px);
      font-weight: 700;
      margin: 16px 0 12px;
      color: var(--surface-fg);
    }
    .muted {
      color: var(--surface-muted);
      font-size: 15px;
      margin: 0 0 32px;
      max-width: 460px;
      line-height: 1.6;
    }
    .actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
    .btn-primary, .btn-secondary {
      padding: 12px 22px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: transform 220ms cubic-bezier(.2,.7,.2,1), box-shadow 220ms;
    }
    .btn-primary {
      background: var(--surface-fg);
      color: var(--surface-bg);
      border: 2px solid var(--surface-fg);
      box-shadow: 3px 3px 0 var(--visual-ink, #1A1814);
    }
    .btn-secondary {
      background: var(--card-bg);
      color: var(--surface-fg);
      border: 2px solid var(--card-border);
      box-shadow: var(--card-shadow);
    }
    .btn-primary:hover, .btn-secondary:hover { transform: translateY(-2px); }
    html[data-theme="magazine"] .btn-primary,
    html[data-theme="magazine"] .btn-secondary { border-radius: 0; }
  </style>
</Layout>
