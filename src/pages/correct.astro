---
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>沉浸式歌词校对舱 | Line-by-Line Mode</title>
    <style is:global>
        :root {
            --primary: #00f2fe;
            --secondary: #4facfe;
            --font-mono: 'Fira Code', 'Monaco', 'Consolas', monospace;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 0; padding: 0; height: 100vh; color: #fff; overflow: hidden;
            display: flex; flex-direction: column;
            background: linear-gradient(-45deg, #13151a, #1a1b26, #0d1117, #1e1e2e);
            background-size: 400% 400%; animation: gradientBG 15s ease infinite;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        header {
            background: rgba(20, 20, 30, 0.4); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding: 1rem 2rem;
            display: flex; justify-content: space-between; align-items: center; z-index: 10;
        }

        h1 { margin: 0; font-size: 1.25rem; font-weight: 600; letter-spacing: 1px; }

        .header-controls { display: flex; gap: 1rem; align-items: center; }

        button {
            background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff; padding: 0.5rem 1.2rem; border-radius: 8px; cursor: pointer;
            font-size: 0.9rem; transition: all 0.3s ease; backdrop-filter: blur(10px);
        }
        button:hover { background: rgba(255, 255, 255, 0.15); border-color: var(--primary); box-shadow: 0 0 15px rgba(0, 242, 254, 0.3); }
        .btn-green { border-color: #56d364; color: #56d364; }
        .btn-green:hover { background: #56d364; color: #000; box-shadow: 0 0 15px rgba(86, 211, 100, 0.4); }

        main { display: flex; flex: 1; overflow: hidden; position: relative; }

        #lyrics-container {
            flex: 1; position: relative;
            mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
        }

        #lyrics-list {
            height: 100%; overflow-y: auto; padding: 40vh 2rem;
            display: flex; flex-direction: column; gap: 2rem; /* 句子之间的间距 */
            box-sizing: border-box; scroll-behavior: smooth;
        }

        #lyrics-list::-webkit-scrollbar { display: none; }
        #lyrics-list { -ms-overflow-style: none; scrollbar-width: none; }

        /* ==========================================
           1. 句子容器样式 (Line Block)
           ========================================== */
        .lyric-line {
            display: flex;
            flex-wrap: wrap; /* 允许单词折行 */
            gap: 0.8rem;
            padding: 1.5rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.03);
            transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
            opacity: 0.3; /* 未激活的句子整体变淡 */
            filter: blur(1px);
        }

        .lyric-line:hover {
            opacity: 0.7; filter: blur(0px);
        }

        /* 激活的句子 */
        .lyric-line.active-line {
            opacity: 1; filter: blur(0px);
            background: rgba(20, 30, 50, 0.4);
            border-color: rgba(255, 255, 255, 0.1);
            transform: scale(1.02);
        }

        /* ==========================================
           2. 紧凑型胶囊单字样式 (Word Block)
           ========================================== */
        .lyric-word {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 0.5rem;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
            min-width: 4rem;
        }

        .lyric-word.active {
            background: rgba(0, 242, 254, 0.1);
            border-color: var(--primary);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5), inset 0 0 10px rgba(0, 242, 254, 0.2);
            transform: translateY(-5px);
        }

        .word-input {
            background: transparent; border: none; color: #fff;
            font-size: 1.4rem; font-weight: 800; text-align: center;
            width: 3rem; margin-bottom: 0.3rem;
        }
        .active .word-input { color: var(--primary); text-shadow: 0 0 10px rgba(0, 242, 254, 0.5); }
        .word-input:focus { outline: none; border-bottom: 2px solid var(--primary); }

        .times {
            display: flex; justify-content: space-between; width: 100%;
            font-family: var(--font-mono); font-size: 0.7rem; color: #8b949e; margin-bottom: 0.4rem;
        }
        .time-input {
            background: transparent; border: none; color: inherit;
            width: 2.2rem; text-align: center; font-size: 0.65rem;
        }
        .time-input:focus { outline: none; color: var(--primary); background: rgba(0,0,0,0.5); }

        /* 超迷你的快捷控制按钮 */
        .time-control-btns { display: flex; gap: 4px; opacity: 0; transition: opacity 0.3s; }
        .lyric-word:hover .time-control-btns, .lyric-word.active .time-control-btns { opacity: 1; }

        .mark-btn {
            background: rgba(255,255,255,0.1); border: none; color: #fff;
            padding: 2px 5px; border-radius: 4px; font-size: 0.65rem; cursor: pointer;
        }
        .mark-btn:hover { background: rgba(255,255,255,0.3); }
        .start-mark:hover { background: #56d364; color: #000; }
        .end-mark:hover { background: #f85149; color: #fff; }

        .lyric-progress {
            position: absolute; bottom: 0; left: 0; height: 3px;
            background: linear-gradient(90deg, var(--secondary), var(--primary));
            width: 0%; box-shadow: 0 0 10px var(--primary);
        }

        #info-panel {
            width: 350px; background: rgba(10, 10, 15, 0.4); backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px); border-left: 1px solid rgba(255, 255, 255, 0.1);
            padding: 2.5rem 2rem; display: flex; flex-direction: column; gap: 2rem; z-index: 5;
        }

        #audio-player { width: 100%; filter: drop-shadow(0 4px 10px rgba(0,0,0,0.5)); outline: none; }

        #toast {
            position: fixed; top: 80px; left: 50%; transform: translate(-50%, -20px);
            background: rgba(86, 211, 100, 0.9); color: #000; padding: 0.6rem 1.5rem;
            border-radius: 30px; font-weight: bold; box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            opacity: 0; pointer-events: none; transition: all 0.3s; z-index: 1000;
        }
        #toast.show { transform: translate(-50%, 0); opacity: 1; }
    </style>
</head>
<body>
    <header>
        <h1>分段沉浸式校对舱 <span style="font-size: 0.8rem; color: var(--primary);">v3.0 Lines</span></h1>
        <div class="header-controls">
            <span id="current-time-display" style="font-family: var(--font-mono); font-size: 1.2rem;">00:00.00</span>
            <input type="file" id="json-upload" accept=".json" style="display: none;">
            <button id="load-json-btn">导入草稿</button>
            <button id="save-json-btn" class="btn-green">导出成品</button>
        </div>
    </header>

    <main>
        <div id="lyrics-container">
            <div id="lyrics-list">
                <div style="text-align: center; color: rgba(255,255,255,0.4); margin-top: 10vh;">
                    点击右上角导入 <b>lyrics_draft.json</b>
                </div>
            </div>
        </div>

        <div id="info-panel">
            <audio id="audio-player" controls src="/test.flac"></audio>
            <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 12px; font-size: 0.85rem; color: #8b949e; line-height: 1.8;">
                <h3 style="color: #fff; margin-top: 0; margin-bottom: 0.5rem;">操作指南</h3>
                <b>智能断句：</b>停顿 > 0.5秒会自动分成新的一行。<br><br>
                <b>快捷键：</b><kbd>Space</kbd> 播放/暂停。<br>
                在胶囊内点击 <b>开</b>/<b>结</b> 抓取时间。底部蓝线是当前字的实时发音进度。
            </div>
        </div>
    </main>

    <div id="toast">操作成功</div>

    <script is:inline>
        let lyrics = []; // 这是原始的、平铺的JSON数组，保持数据结构不受破坏
        let currentWordIndex = -1;
        let animationFrameId = null;

        const audioPlayer = document.getElementById('audio-player');
        const currentTimeDisplay = document.getElementById('current-time-display');
        const lyricsList = document.getElementById('lyrics-list');
        const jsonUpload = document.getElementById('json-upload');

        function showToast(message, isError = false) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.style.background = isError ? 'rgba(248, 81, 73, 0.9)' : 'rgba(86, 211, 100, 0.9)';
            toast.style.color = isError ? '#fff' : '#000';
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2000);
        }

        document.getElementById('load-json-btn').onclick = () => jsonUpload.click();
        
        jsonUpload.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(evt) {
                try {
                    lyrics = JSON.parse(evt.target.result);
                    renderLyricsLines(); // 调用新的分行渲染逻辑
                    showToast("✅ 数据导入成功");
                } catch(err) {
                    showToast("❌ 数据损坏", true);
                }
            };
            reader.readAsText(file);
        });

        // ==========================================
        // 核心进化：智能分句与胶囊渲染
        // ==========================================
        function renderLyricsLines() {
            lyricsList.innerHTML = '';
            
            // 1. 智能分行算法：时间差超过 0.5 秒视为换行
            const lines = [];
            let currentLine = [];
            
            for(let i = 0; i < lyrics.length; i++) {
                // 把原始在数组里的索引挂上去，方便操作修改
                currentLine.push({...lyrics[i], originalIndex: i});
                
                // 判断是否需要换行
                if (i === lyrics.length - 1 || (lyrics[i+1].start - lyrics[i].end > 0.5)) {
                    lines.push(currentLine);
                    currentLine = [];
                }
            }

            // 2. 渲染 UI
            lines.forEach((line, lineIndex) => {
                const lineDiv = document.createElement('div');
                lineDiv.className = 'lyric-line';
                lineDiv.id = `line-${lineIndex}`;
                
                line.forEach(item => {
                    const idx = item.originalIndex;
                    const wordDiv = document.createElement('div');
                    wordDiv.className = 'lyric-word';
                    wordDiv.id = `lyric-item-${idx}`;
                    
                    wordDiv.onclick = (e) => {
                        if (['INPUT', 'BUTTON'].includes(e.target.tagName)) return;
                        audioPlayer.currentTime = item.start;
                        audioPlayer.play();
                    };

                    wordDiv.innerHTML = `
                        <input type="text" class="word-input" value="${item.word}" onchange="updateWord(${idx}, this.value)">
                        <div class="times">
                            <input type="number" step="0.01" class="time-input" value="${item.start.toFixed(2)}" onchange="updateStart(${idx}, this.value)">
                            <input type="number" step="0.01" class="time-input" value="${item.end.toFixed(2)}" onchange="updateEnd(${idx}, this.value)">
                        </div>
                        <div class="time-control-btns">
                            <button class="mark-btn start-mark" onclick="markStart(${idx})">开</button>
                            <button class="mark-btn end-mark" onclick="markEnd(${idx})">结</button>
                            <button class="mark-btn" onclick="addAfter(${idx})">➕</button>
                            <button class="mark-btn" onclick="deleteItem(${idx})">🗑</button>
                        </div>
                        <div class="lyric-progress" id="progress-${idx}"></div>
                    `;
                    lineDiv.appendChild(wordDiv);
                });
                
                lyricsList.appendChild(lineDiv);
            });
        }

        function markStart(index) { lyrics[index].start = roundToTwo(audioPlayer.currentTime); renderLyricsLines(); }
        function markEnd(index) { lyrics[index].end = roundToTwo(audioPlayer.currentTime); renderLyricsLines(); }
        function addAfter(index) {
            const time = roundToTwo(audioPlayer.currentTime);
            lyrics.splice(index + 1, 0, { word: "新", start: time, end: time + 0.3 });
            renderLyricsLines();
        }
        function deleteItem(index) { lyrics.splice(index, 1); renderLyricsLines(); }
        function updateWord(index, value) { lyrics[index].word = value; }
        function updateStart(index, value) { lyrics[index].start = parseFloat(value) || 0; }
        function updateEnd(index, value) { lyrics[index].end = parseFloat(value) || 0; }
        function roundToTwo(num) { return +(Math.round(num + "e+2") + "e-2"); }

        // ==========================================
        // UI 刷新引擎：按行滚动，按字高亮
        // ==========================================
        function startAnimationLoop() {
            if (!audioPlayer.paused) {
                updateUI();
                animationFrameId = requestAnimationFrame(startAnimationLoop);
            }
        }

        audioPlayer.addEventListener('play', () => {
            if (animationFrameId) cancelAnimationFrame(animationFrameId);
            startAnimationLoop();
        });
        audioPlayer.addEventListener('pause', () => {
            if (animationFrameId) cancelAnimationFrame(animationFrameId);
            updateUI();
        });
        audioPlayer.addEventListener('seeked', updateUI); 

        function updateUI() {
            const time = audioPlayer.currentTime;
            const min = Math.floor(time / 60).toString().padStart(2, '0');
            const sec = (time % 60).toFixed(2).toString().padStart(5, '0');
            currentTimeDisplay.innerText = `${min}:${sec}`;

            let nextIndex = lyrics.findIndex(item => time >= item.start && time <= item.end);
            
            if (nextIndex === -1 && lyrics.length > 0) {
                for (let i = lyrics.length - 1; i >= 0; i--) {
                    if (time >= lyrics[i].start) { nextIndex = i; break; }
                }
            }

            if (nextIndex !== currentWordIndex && nextIndex !== -1) {
                // 清理旧状态
                if (currentWordIndex !== -1) {
                    const lastWord = document.getElementById(`lyric-item-${currentWordIndex}`);
                    if (lastWord) {
                        lastWord.classList.remove('active');
                        document.getElementById(`progress-${currentWordIndex}`).style.width = '0%';
                        // 移除旧行的激活状态
                        const lastLine = lastWord.closest('.lyric-line');
                        if (lastLine) lastLine.classList.remove('active-line');
                    }
                }

                currentWordIndex = nextIndex;
                const activeWord = document.getElementById(`lyric-item-${currentWordIndex}`);
                if (activeWord) {
                    activeWord.classList.add('active');
                    
                    // 获取所在的行
                    const currentLine = activeWord.closest('.lyric-line');
                    if (currentLine) {
                        currentLine.classList.add('active-line');
                        // ⭐️ 改动：滚动页面时，以“整句”为单位居中，彻底告别单字跳动的眩晕感
                        currentLine.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            }

            if (currentWordIndex !== -1) {
                const activeData = lyrics[currentWordIndex];
                const progressBar = document.getElementById(`progress-${currentWordIndex}`);
                if (progressBar) {
                    if (time < activeData.start) progressBar.style.width = '0%';
                    else if (time > activeData.end) progressBar.style.width = '100%';
                    else {
                        const duration = activeData.end - activeData.start;
                        if (duration > 0) {
                            progressBar.style.width = `${((time - activeData.start) / duration) * 100}%`;
                        }
                    }
                }
            }
        }

        document.addEventListener('keydown', (e) => {
            if (e.target.tagName === 'INPUT') return;
            if (e.code === 'Space') {
                e.preventDefault();
                audioPlayer.paused ? audioPlayer.play() : audioPlayer.pause();
            }
        });

        document.getElementById('save-json-btn').addEventListener('click', () => {
            if(lyrics.length === 0) return;
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(lyrics, null, 2));
            const node = document.createElement('a');
            node.setAttribute("href", dataStr);
            node.setAttribute("download", "lyrics_corrected.json");
            document.body.appendChild(node); node.click(); node.remove();
            showToast("✅ 数据导出成功");
        });
    </script>
</body>
</html>