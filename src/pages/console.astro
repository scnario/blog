---
import Layout from '../layouts/Layout.astro';
// 注意：服务端不需要在这里连数据库，因为我们要让浏览器客户端直接和数据库通信
---

<Layout title="主控台 | SYSTEM.CONSOLE">
  <div class="max-w-3xl mx-auto mt-10 relative z-10">
    
    <div class="mb-8 border-b border-gray-800 pb-4">
      <h1 class="text-4xl font-bold text-pink-500 tracking-widest animate-pulse">>_ OVERRIDE_CONSOLE</h1>
      <p class="text-gray-500 font-mono mt-2">身份验证与数据注入协议已就绪...</p>
    </div>

    <div id="login-section" class="p-8 border border-pink-900/50 bg-black/60 backdrop-blur-md hifi-card transition-all">
      <h2 class="text-xl text-pink-400 mb-6">> 验证管理员权限</h2>
      <div class="flex flex-col gap-4">
        <input type="email" id="email" placeholder="ADMIN_EMAIL" class="bg-gray-900/50 border border-gray-700 text-cyan-300 px-4 py-3 focus:outline-none focus:border-pink-500 font-mono">
        <input type="password" id="password" placeholder="PASSWORD" class="bg-gray-900/50 border border-gray-700 text-cyan-300 px-4 py-3 focus:outline-none focus:border-pink-500 font-mono">
        <button id="login-btn" class="mt-4 bg-pink-600/20 border border-pink-500 text-pink-400 px-6 py-3 hover:bg-pink-600/40 hover:text-white transition-colors font-bold tracking-widest">
          [ INITIATE_LOGIN ]
        </button>
      </div>
      <div id="login-error" class="text-red-500 mt-4 text-sm hidden font-mono"></div>
    </div>

    <div id="editor-section" class="hidden p-8 border border-cyan-900/50 bg-black/60 backdrop-blur-md hifi-card transition-all">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl text-cyan-400">> 建立新区块 (New Record)</h2>
        <button id="logout-btn" class="text-gray-500 hover:text-red-400 text-sm font-mono">[ LOGOUT ]</button>
      </div>
      
      <div class="flex flex-col gap-6">
        <div class="flex gap-4">
          <input type="text" id="post-title" placeholder="文章标题 (Title)" class="flex-1 bg-gray-900/50 border border-gray-700 text-cyan-300 px-4 py-3 focus:outline-none focus:border-cyan-500 font-mono">
          <input type="text" id="post-slug" placeholder="URL标识 (Slug, 例如: my-diary)" class="w-1/3 bg-gray-900/50 border border-gray-700 text-gray-400 px-4 py-3 focus:outline-none focus:border-cyan-500 font-mono">
        </div>
        
        <textarea id="post-content" rows="12" placeholder="在此输入 Markdown 信号..." class="bg-gray-900/50 border border-gray-700 text-gray-300 px-4 py-3 focus:outline-none focus:border-cyan-500 font-mono resize-y"></textarea>
        
        <div class="flex items-center justify-between mt-2">
          <label class="flex items-center gap-2 text-gray-400 cursor-pointer">
            <input type="checkbox" id="post-publish" checked class="w-4 h-4 accent-cyan-500">
            <span class="font-mono text-sm">> 立即发布 (is_published)</span>
          </label>
          
          <button id="submit-btn" class="bg-cyan-600/20 border border-cyan-500 text-cyan-400 px-8 py-3 hover:bg-cyan-600/40 hover:text-white transition-colors font-bold tracking-widest">
            [ UPLOAD_DATA ]
          </button>
        </div>
      </div>
      <div id="submit-status" class="mt-4 text-sm font-mono hidden"></div>
    </div>

  </div>
</Layout>

<script>
  import PocketBase from 'pocketbase';

  document.addEventListener('DOMContentLoaded', () => {
    // 换成你云端的真实地址
    const pb = new PocketBase('https://db.91917788.xyz'); 
    
    const loginSection = document.getElementById('login-section');
    const editorSection = document.getElementById('editor-section');
    
    // 检查本地是否已经有登录令牌
    if (pb.authStore.isValid) {
      showEditor();
    }

    // --- 登录逻辑 ---
    document.getElementById('login-btn').addEventListener('click', async () => {
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const pass = (document.getElementById('password') as HTMLInputElement).value;
      const errorDiv = document.getElementById('login-error');
      
      try {
        // 使用 admins 表进行超级管理员登录
        await pb.admins.authWithPassword(email, pass);
        errorDiv.classList.add('hidden');
        showEditor();
      } catch (err) {
        errorDiv.textContent = "> 访问拒绝：凭证无效或网络异常。";
        errorDiv.classList.remove('hidden');
      }
    });

    // --- 注销逻辑 ---
    document.getElementById('logout-btn').addEventListener('click', () => {
      pb.authStore.clear();
      loginSection.classList.remove('hidden');
      editorSection.classList.add('hidden');
    });

    // --- 提交文章逻辑 ---
    document.getElementById('submit-btn').addEventListener('click', async () => {
      const title = (document.getElementById('post-title') as HTMLInputElement).value;
      const slug = (document.getElementById('post-slug') as HTMLInputElement).value;
      const content = (document.getElementById('post-content') as HTMLTextAreaElement).value;
      const isPublished = (document.getElementById('post-publish') as HTMLInputElement).checked;
      const statusDiv = document.getElementById('submit-status');

      if (!title || !slug || !content) {
        showStatus("> 错误：标题、Slug 和正文不能为空。", 'text-red-500');
        return;
      }

      showStatus("> 正在向数据库注入信号...", 'text-yellow-500');

      try {
        const data = {
          title: title,
          slug: slug,
          content: content,
          is_published: isPublished
        };
        // 向 posts 表写入数据
        await pb.collection('posts').create(data);
        showStatus("> 注入成功！数据区块已同步。", 'text-green-400');
        
        // 清空表单，方便写下一篇
        (document.getElementById('post-title') as HTMLInputElement).value = '';
        (document.getElementById('post-slug') as HTMLInputElement).value = '';
        (document.getElementById('post-content') as HTMLTextAreaElement).value = '';
        
      } catch (err) {
        showStatus(`> 注入失败：${err.message}`, 'text-red-500');
      }
    });

    function showEditor() {
      loginSection.classList.add('hidden');
      editorSection.classList.remove('hidden');
    }

    function showStatus(msg: string, colorClass: string) {
      const statusDiv = document.getElementById('submit-status');
      statusDiv.textContent = msg;
      statusDiv.className = `mt-4 text-sm font-mono block ${colorClass}`;
    }
  });
</script>