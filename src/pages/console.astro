---
// biome-ignore-all lint/correctness/noUnusedImports lint/correctness/noUnusedVariables: Astro frontmatter symbols are consumed by the template.
/**
 * 控制台 — 6 tab 管理面板
 * 文章 / 笔记 / 日记 / 站点设置 / 主题 / 布局
 *
 * 设计要点：
 * - 登录态由 pb.authStore 维持（localStorage）；服务端不参与
 * - tab 切换：URL hash + JS 切 .active 类（不用框架）
 * - 所有写操作走客户端 PB SDK；写完调 /api/invalidate-cache 让 SSR 缓存失效
 * - schema 缺字段时 UI 应仍能渲染（写入失败给提示而不是崩）
 */
import Layout from '../layouts/Layout.astro';
import DiaryTab from '../components/console/DiaryTab.astro';
import LayoutTab from '../components/console/LayoutTab.astro';
import NotesTab from '../components/console/NotesTab.astro';
import PostsTab from '../components/console/PostsTab.astro';
import SettingsTab from '../components/console/SettingsTab.astro';
import ThemeTab from '../components/console/ThemeTab.astro';

const clientPbUrl = import.meta.env.PUBLIC_PB_URL || process.env.PB_URL || import.meta.env.PB_URL || 'https://example-pocketbase.invalid';
---

<Layout title="控制台 | 管理面板" showSidebar={false} showToc={false}>
  <div class="console-root">
    <!-- 未登录 -->
    <section id="login-section" class="login-card">
      <div class="login-head">
        <div class="mono kicker">CONSOLE / AUTH</div>
        <h1>登录管理控制台</h1>
        <p class="muted">使用 PocketBase 超级管理员账号登录。</p>
      </div>
      <div class="form">
        <label>邮箱
          <input type="email" id="email" placeholder="admin@example.com" autocomplete="username" />
        </label>
        <label>密码
          <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" />
        </label>
        <button id="login-btn" class="btn-primary">登录</button>
        <div id="login-error" class="error" style="display:none"></div>
      </div>
    </section>

    <!-- 已登录 -->
    <section id="admin-section" style="display:none">
      <header class="admin-head">
        <div>
          <div class="mono kicker">CONSOLE</div>
          <h1>管理控制台</h1>
          <p class="muted" id="admin-email">—</p>
        </div>
        <button id="logout-btn" class="btn-ghost">登出</button>
      </header>

      <nav class="tabs">
        <a href="#posts" data-tab="posts" class="tab active">📰 文章</a>
        <a href="#notes" data-tab="notes" class="tab">💡 笔记</a>
        <a href="#diary" data-tab="diary" class="tab">📔 日记</a>
        <a href="#settings" data-tab="settings" class="tab">⚙️ 站点设置</a>
        <a href="#theme" data-tab="theme" class="tab">🎨 主题</a>
        <a href="#layout" data-tab="layout" class="tab">🧩 布局</a>
      </nav>

      <aside class="console-sidecar">
        <h4>站点 · 概览</h4>
        <div class="ed-c-stat">
          <div class="v tab-num" id="sidecar-total">—</div>
          <div class="l">总条目 · 全部内容</div>
        </div>
        <div class="sidecar-grid">
          <div class="ed-c-stat"><div class="v tab-num" id="sidecar-posts">—</div><div class="l">博客</div></div>
          <div class="ed-c-stat"><div class="v tab-num" id="sidecar-notes">—</div><div class="l">笔记</div></div>
        </div>
        <h4>近期活动</h4>
        <div id="sidecar-activity" class="sidecar-activity">
          <div class="ed-c-act"><span class="dot"></span><div><span class="who">system</span> 等待登录后同步</div><span class="when">now</span></div>
        </div>
        <h4>系统</h4>
        <div class="sidecar-system mono">
          <div>PB · 0.26.x · <span style="color:#6EE7B7">已连接</span></div>
          <div>cache · 5 min · <a href="javascript:fetch('/api/invalidate-cache').then(()=>alert('缓存已刷新 ✓'))" style="color:#6EE7B7;">手动失效</a></div>
          <div>theme · <span id="sidecar-theme">bento-webui</span></div>
          <div style="margin-top:6px"><a href="/" target="_blank" style="color:var(--surface-link);text-decoration:none;">→ 打开首页查看效果</a></div>
        </div>
      </aside>

      <PostsTab />
      <NotesTab />
      <DiaryTab />
      <SettingsTab />
      <ThemeTab />
      <LayoutTab />
    </section>
  </div>

  <style is:global>
    /* ===== tab 面板切换 — 必须 is:global 才能命中子组件 ===== */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; animation: consoleFadeIn 220ms ease; }

    .tab-panel {
      grid-column: 2;
      grid-row: 2;
      overflow: auto;
      padding: 24px 28px;
      background: #0E0E10;
    }

    @keyframes consoleFadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <style is:global>
    .console-root { max-width: 980px; margin: 0 auto; padding: 8px 4px 80px; }

    .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }
    .kicker { font-size: 11px; color: #8A8A94; letter-spacing: 0.08em; margin-bottom: 6px; }
    .muted { color: #8A8A94; }
    .small { font-size: 12px; }
    .error {
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.3);
      color: #B91C1C;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
    }

    /* Login */
    .login-card {
      max-width: 440px;
      margin: 60px auto;
      background: #FFFFFF;
      border-radius: 24px;
      padding: 36px;
      box-shadow: 0 16px 40px rgba(0,0,0,0.08);
    }
    .login-head h1 {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 4px 0;
    }
    .login-card .form { display: grid; gap: 14px; margin-top: 20px; }

    label {
      display: flex;
      flex-direction: column;
      gap: 6px;
      font-size: 13px;
      color: #52525B;
      font-weight: 500;
    }
    label.checkbox {
      flex-direction: row;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }
    input[type="text"], input[type="email"], input[type="password"], input[type="date"],
    input[type="number"], select, textarea {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #E4E4E7;
      border-radius: 10px;
      font-size: 14px;
      background: #FAFAF7;
      color: #1A1A1F;
      font-family: inherit;
      transition: border-color 160ms;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: #6B5BFF;
      background: #FFFFFF;
    }
    input[type="color"] {
      width: 56px;
      height: 36px;
      border: 1px solid #E4E4E7;
      border-radius: 8px;
      cursor: pointer;
      background: transparent;
      padding: 2px;
    }

    .btn-primary {
      background: #1A1A1F;
      color: #FFFFFF;
      border: none;
      padding: 10px 20px;
      border-radius: 10px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 160ms, box-shadow 160ms;
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(0,0,0,0.15); }
    .btn-ghost {
      background: transparent;
      color: #52525B;
      border: 1px solid #E4E4E7;
      padding: 8px 14px;
      border-radius: 10px;
      font-size: 13px;
      cursor: pointer;
      transition: background 160ms, color 160ms;
    }
    .btn-ghost:hover { background: #F4F4F5; color: #1A1A1F; }

    /* Admin layout */
    .admin-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin: 20px 0 28px;
    }
    .admin-head h1 {
      font-size: clamp(24px, 3vw, 34px);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 4px 0 4px;
    }

    .tabs {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      padding: 6px;
      background: #FFFFFF;
      border-radius: 16px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.05);
      margin-bottom: 24px;
      overflow-x: auto;
    }
    .tab {
      padding: 10px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      color: #52525B;
      text-decoration: none;
      white-space: nowrap;
      transition: background 160ms, color 160ms;
    }
    .tab:hover { background: #F4F4F5; color: #1A1A1F; }
    .tab.active { background: #1A1A1F; color: #FFFFFF; }

    .panel-head { margin-bottom: 18px; }
    .panel-head h2 {
      font-size: 22px;
      font-weight: 800;
      margin: 0 0 4px;
      letter-spacing: -0.01em;
    }

    .card {
      background: #FFFFFF;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.05);
      margin-bottom: 20px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 16px;
    }
    .form-grid .span-2 { grid-column: span 2; }
    @media (max-width: 700px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-grid .span-2 { grid-column: span 1; }
    }

    .list { display: grid; gap: 8px; }
    .list-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      background: #FAFAF7;
      border-radius: 10px;
      font-size: 13px;
    }
    .list-item .badge {
      padding: 2px 8px;
      border-radius: 999px;
      background: rgba(168,230,207,0.4);
      color: #065F46;
      font-size: 11px;
      font-weight: 600;
    }
    .list-item .title { flex: 1; font-weight: 600; color: #1A1A1F; }
    .list-item .actions { display: flex; gap: 6px; }
    .list-item .actions button {
      padding: 4px 10px;
      border-radius: 8px;
      border: 1px solid #E4E4E7;
      background: #FFFFFF;
      font-size: 11px;
      cursor: pointer;
      color: #52525B;
    }
    .list-item .actions button:hover { background: #F4F4F5; color: #1A1A1F; }
    .list-item .actions button.danger { color: #B91C1C; border-color: rgba(239,68,68,0.3); }

    .theme-grid, .preset-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }
    .theme-card, .preset-card {
      display: flex; gap: 10px; align-items: flex-start;
      padding: 14px;
      border: 1px solid #E4E4E7;
      border-radius: 14px;
      cursor: pointer;
      transition: border-color 160ms, background 160ms;
      background: #FAFAF7;
    }
    .theme-card:hover, .preset-card:hover { border-color: #6B5BFF; background: #FFFFFF; }
    .theme-card input, .preset-card input { margin-top: 4px; }
    .theme-name, .preset-name { font-weight: 700; font-size: 14px; margin-bottom: 4px; }

    code {
      background: rgba(0,0,0,0.05);
      padding: 1px 6px;
      border-radius: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.88em;
    }

    .status-success { color: #047857; }
    .status-error { color: #B91C1C; }
    .status-pending { color: #B7791F; }

    /* ===== Editorial A dark console shell ===== */
    .console-root {
      max-width: none;
      margin: -32px -24px -96px;
      padding: 0;
      min-height: calc(100vh - 57px);
      background: #0E0E10;
      color: #E4E4E7;
      border-top: 1px solid #1F1F23;
    }
    #admin-section {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr) 320px;
      grid-template-rows: 44px 1fr;
      min-height: calc(100vh - 58px);
    }
    .admin-head {
      grid-column: 1 / -1;
      margin: 0;
      height: 44px;
      padding: 0 16px;
      background: #0A0A0C;
      border-bottom: 1px solid #1F1F23;
      gap: 16px;
    }
    .admin-head::before {
      content: '';
      width: 11px; height: 11px;
      border-radius: 99px;
      background: #B8311E;
      box-shadow: 18px 0 0 #FBBF24, 36px 0 0 #2C5530;
      margin-right: 42px;
      flex-shrink: 0;
    }
    .admin-head h1 {
      font-family: 'Noto Serif SC', serif;
      font-size: 16px;
      letter-spacing: 0;
      color: #E4E4E7;
    }
    .admin-head .kicker { display: none; }
    .admin-head .muted { color: #6B6873; font-size: 12px; margin: 0; }
    .tabs {
      grid-column: 1;
      grid-row: 2;
      display: block;
      margin: 0;
      padding: 14px 0;
      border-radius: 0;
      background: #0A0A0C;
      border-right: 1px solid #1F1F23;
      box-shadow: none;
      overflow: auto;
    }
    .tabs::before,
    .tabs::after {
      display: block;
      padding: 14px 16px 6px;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #52525B;
    }
    .tabs::before { content: '内容'; }
    .tabs::after { content: '站点'; margin-top: 10px; }
    .tab {
      display: flex;
      align-items: center;
      border-radius: 0;
      padding: 8px 16px;
      color: #A1A1AA;
      border-left: 2px solid transparent;
      font-size: 13px;
    }
    .tab:hover { background: #131316; color: #E4E4E7; }
    .tab.active {
      background: #18181B;
      color: #E4E4E7;
      border-left-color: var(--console-accent, #B8311E);
    }
    .console-sidecar {
      grid-column: 3;
      grid-row: 2;
      background: #0A0A0C;
      border-left: 1px solid #1F1F23;
      padding: 18px;
      overflow: auto;
    }
    .console-sidecar h4 {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #71717A;
      margin: 0 0 10px;
      font-weight: 600;
    }
    .sidecar-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px; }
    .ed-c-stat {
      background: #131316;
      border: 1px solid #27272A;
      border-radius: 8px;
      padding: 14px;
      margin-bottom: 10px;
    }
    .ed-c-stat .v {
      font-size: 24px;
      font-weight: 700;
      font-family: 'Noto Serif SC', serif;
      letter-spacing: -0.02em;
      color: #E4E4E7;
    }
    .ed-c-stat .l { font-size: 11px; color: #71717A; margin-top: 2px; }
    .ed-c-act {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px solid #18181B;
      font-size: 12px;
      color: #A1A1AA;
    }
    .ed-c-act .dot { width: 6px; height: 6px; border-radius: 99px; background: var(--console-accent, #B8311E); flex-shrink: 0; }
    .ed-c-act .who { color: #E4E4E7; font-weight: 600; }
    .ed-c-act .when { color: #52525B; margin-left: auto; font-family: var(--font-mono); font-size: 10px; }
    .sidecar-system { font-size: 11px; line-height: 1.8; color: #A1A1AA; }
    .panel-head h2,
    .card h3 { color: #E4E4E7; }
    .panel-head .muted,
    .muted { color: #8A8A94; }
    .card,
    .login-card {
      background: #131316;
      border: 1px solid #27272A;
      box-shadow: none;
      color: #D4D4D8;
      border-radius: 10px;
    }
    input[type="text"], input[type="email"], input[type="password"], input[type="date"],
    input[type="number"], select, textarea {
      background: #18181B;
      border: 1px solid #27272A;
      color: #E4E4E7;
      border-radius: 6px;
    }
    input:focus, select:focus, textarea:focus {
      background: #18181B;
      border-color: var(--console-accent, #B8311E);
    }
    label { color: #A1A1AA; }
    .btn-primary {
      background: var(--console-accent, #B8311E);
      border: 1px solid var(--console-accent, #B8311E);
      border-radius: 6px;
    }
    .btn-ghost {
      background: #18181B;
      border: 1px solid #27272A;
      color: #E4E4E7;
      border-radius: 6px;
    }
    .btn-ghost:hover { background: #27272A; color: #FFFFFF; }
    .list-item,
    .theme-card,
    .preset-card {
      background: #18181B;
      border: 1px solid #27272A;
      color: #D4D4D8;
      border-radius: 6px;
    }
    .list-item .title { color: #E4E4E7; }
    code { background: #18181B; color: #E4E4E7; border: 1px solid #27272A; }
    @media (max-width: 1100px) {
      #admin-section { grid-template-columns: 200px minmax(0, 1fr); }
      .console-sidecar { display: none; }
    }
    @media (max-width: 760px) {
      .console-root { margin: -20px -16px -80px; }
      #admin-section { display: block; min-height: auto; }
      .admin-head { position: sticky; top: 0; z-index: 2; }
      .tabs { display: flex; overflow-x: auto; border-right: 0; border-bottom: 1px solid #1F1F23; }
      .tabs::before, .tabs::after { display: none; }
      .tab-panel { padding: 18px; }
    }
  </style>
</Layout>

<script define:vars={{ clientPbUrl }} is:inline>
  window.__PB_URL__ = clientPbUrl;
</script>

<script>
  import { $, errorMessage, pb, runConsoleLoaders, val } from '../lib/console-client';

  type AuthModel = { email?: string };

  function showAdmin() {
    const login = $('login-section');
    const admin = $('admin-section');
    if (login) login.style.display = 'none';
    if (admin) admin.style.display = 'grid';
    const emailEl = $('admin-email');
    if (emailEl) emailEl.textContent = (pb.authStore.model as AuthModel | null)?.email || '已登录';
    initTabs();
    runConsoleLoaders();
  }
  function showLogin() {
    const login = $('login-section');
    const admin = $('admin-section');
    if (login) login.style.display = 'block';
    if (admin) admin.style.display = 'none';
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (pb.authStore.isValid) {
      showAdmin();
    } else {
      showLogin();
    }

    $('login-btn')?.addEventListener('click', async () => {
      const email = val('email');
      const pw = val('password');
      const err = $('login-error');
      if (err) err.style.display = 'none';
      try {
        await pb.admins.authWithPassword(email, pw);
        showAdmin();
      } catch (e) {
        if (err) {
          err.textContent = '登录失败：' + (errorMessage(e) || '凭据无效');
          err.style.display = 'block';
        }
      }
    });

    $('logout-btn')?.addEventListener('click', () => {
      pb.authStore.clear();
      showLogin();
    });
  });

  function initTabs() {
    const tabs = document.querySelectorAll<HTMLAnchorElement>('.tab');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
    function activate(name: string) {
      tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === name));
      panels.forEach(p => p.classList.toggle('active', p.dataset.panel === name));
    }
    tabs.forEach(t => {
      t.addEventListener('click', e => {
        e.preventDefault();
        const name = t.dataset.tab!;
        history.replaceState(null, '', '#' + name);
        activate(name);
      });
    });
    const initial = (location.hash || '#posts').slice(1);
    activate(initial || 'posts');
  }
</script>
