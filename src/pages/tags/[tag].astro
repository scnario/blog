---
// biome-ignore-all lint/correctness/noUnusedImports lint/correctness/noUnusedVariables: Astro frontmatter symbols are consumed by the template.
/**
 * 标签过滤页 — 按 tag 筛选文章
 */
import Layout from '../../layouts/Layout.astro';
import { getArticlesByTag } from '../../lib/queries';

const { tag } = Astro.params;
if (!tag) return Astro.redirect('/articles');

const page = parseInt(Astro.url.searchParams.get('page') ?? '1') || 1;
const { items: articles, page: currentPage, totalPages, totalItems } = await getArticlesByTag(tag, page);

function fmtDate(s: string): string {
  if (!s) return '';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}
---

<Layout title={`标签: ${tag} · 博客`} showSidebar={true} showToc={false}>
  <header class="page-head">
    <div class="kicker mono">TAG</div>
    <h1># {tag}</h1>
    <p class="muted">共 {totalItems} 篇文章</p>
  </header>

  <a href="/articles" class="back-link mono">&lt; 返回全部博客</a>

  {articles.length === 0 ? (
    <div class="empty">
      <div class="empty-icon">🏷️</div>
      <div class="empty-title">这个标签下还没有文章</div>
    </div>
  ) : (
    <>
      <div class="grid">
        {articles.map(p => (
          <a href={`/articles/${p.slug}`} class="card">
            <span class="tag">{p.emoji} {p.tag}</span>
            <h2 class="title">{p.title}</h2>
            <p class="excerpt">{p.excerpt}</p>
            <div class="date mono">{fmtDate(p.created)}</div>
          </a>
        ))}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="分页导航">
          {currentPage > 1 ? (
            <a href={`/tags/${tag}?page=${currentPage - 1}`} class="page-btn">← 上一页</a>
          ) : (
            <span class="page-btn disabled">← 上一页</span>
          )}
          <span class="page-info mono">{currentPage} / {totalPages}</span>
          {currentPage < totalPages ? (
            <a href={`/tags/${tag}?page=${currentPage + 1}`} class="page-btn">下一页 →</a>
          ) : (
            <span class="page-btn disabled">下一页 →</span>
          )}
        </nav>
      )}
    </>
  )}

  <style>
    .page-head { margin-bottom: 20px; }
    .kicker {
      font-size: 11px;
      color: var(--surface-faint);
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 0;
      color: var(--surface-fg);
    }
    .muted { color: var(--surface-muted); margin: 6px 0 0; }
    .mono { font-family: var(--font-mono); }

    .back-link {
      display: inline-block;
      margin-bottom: 24px;
      color: var(--surface-link);
      text-decoration: none;
      font-size: 13px;
    }
    .back-link:hover { text-decoration: underline; }

    .empty {
      padding: 48px 24px;
      text-align: center;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      box-shadow: var(--card-shadow);
      color: var(--card-fg);
    }
    .empty-icon { font-size: 48px; margin-bottom: 12px; }
    .empty-title { font-size: 16px; color: var(--surface-muted); }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
    }
    .card {
      display: block;
      background: var(--card-bg);
      border: 2px solid var(--card-border);
      border-radius: 18px;
      padding: 22px;
      text-decoration: none;
      color: var(--card-fg);
      box-shadow: var(--card-shadow);
      transition: transform 220ms cubic-bezier(.2,.8,.2,1), box-shadow 220ms;
    }
    .card:hover {
      transform: translate(2px, 2px);
      box-shadow: 2px 2px 0 var(--visual-ink, #1A1814);
    }
    .tag {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.03em;
      background: var(--prose-tag-bg);
      color: var(--prose-tag-fg);
    }
    .title {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      line-height: 1.35;
      margin: 12px 0 8px;
      letter-spacing: -0.01em;
      color: var(--card-fg);
    }
    .excerpt {
      font-size: 13.5px;
      color: var(--surface-muted);
      line-height: 1.65;
      margin: 0 0 14px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .date {
      font-size: 11px;
      color: var(--surface-faint);
      letter-spacing: 0.02em;
    }

    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 16px;
      margin-top: 36px;
      padding: 16px 0;
    }
    .page-btn {
      padding: 8px 18px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      color: var(--surface-link);
      border: 1px solid var(--card-border);
      background: var(--card-bg);
      transition: transform 180ms, box-shadow 180ms;
    }
    .page-btn:hover {
      transform: translateY(-1px);
      box-shadow: var(--card-shadow);
    }
    .page-btn.disabled {
      color: var(--surface-faint);
      pointer-events: none;
      opacity: 0.4;
    }
    .page-info {
      font-size: 13px;
      color: var(--surface-muted);
    }

    html[data-theme="bento-webui"] .card {
      box-shadow: var(--visual-shadow, 4px 4px 0 #1A1814);
      border-color: var(--visual-ink, #1A1814);
    }
    html[data-theme="magazine"] .card,
    html[data-theme="magazine"] .empty { border-radius: 0; }
    html[data-theme="magazine"] .title { text-transform: uppercase; letter-spacing: 0.02em; }
    html[data-theme="magazine"] .tag { border-radius: 0; }
    html[data-theme="magazine"] .page-btn { border-radius: 0; }
  </style>

  <script>
    import { inViewStagger } from '../../lib/motion';
    document.addEventListener('astro:page-load', () => {
      inViewStagger('.grid > .card', { staggerMs: 60, y: 18 });
    });
  </script>
</Layout>
