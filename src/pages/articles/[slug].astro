---
/**
 * 博客详情页 — Markdown 渲染 + TOC 抽取 + 上下篇导航
 *
 * Prose 全部走 --prose-* 变量，5 套主题下都有正确对比度。
 */
import Layout from '../../layouts/Layout.astro';
import { getArticleBySlug, getAdjacentArticles, getRelatedArticles } from '../../lib/queries';
import { marked } from 'marked';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/articles');

const article = await getArticleBySlug(slug);
if (!article) return Astro.redirect('/articles');

const { prev: prevArticle, next: nextArticle } = await getAdjacentArticles(slug);
const relatedArticles = await getRelatedArticles(slug, article.tag, 3);

const extractedHeadings: Array<{ depth: number; slug: string; text: string }> = [];
const renderer = new marked.Renderer();

renderer.heading = function (textOrObj: any, level: any) {
  const actualText = typeof textOrObj === 'object' ? textOrObj.text : textOrObj;
  const actualLevel = typeof textOrObj === 'object' ? textOrObj.depth : level;
  const anchor = String(actualText).toLowerCase()
    .replace(/[\s_]+/g, '-')
    .replace(/[^\w\u4e00-\u9fa5-]/g, '');
  extractedHeadings.push({ depth: actualLevel, slug: anchor, text: actualText });
  return `<h${actualLevel} id="${anchor}" class="scroll-mt-24">${actualText}</h${actualLevel}>\n`;
};

renderer.image = function (href: string, title: string | null, text: string) {
  return `<img src="${href}" alt="${text || ''}" loading="lazy" decoding="async"${title ? ` title="${title}"` : ''} />`;
};

marked.use({ renderer, gfm: true });

const parsedContent = marked.parse(article.content);

function fmtDate(s: string): string {
  if (!s) return '';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? s : d.toISOString().slice(0, 10);
}

function readingTime(text: string): string {
  const words = text.trim().split(/\s+/).length;
  const cjk = (text.match(/[\u4e00-\u9fa5\u3040-\u30ff]/g) || []).length;
  // 中文 ~500字/min，英文 ~200词/min
  const mins = Math.ceil(Math.max(cjk / 500, words / 200));
  return `约 ${mins} 分钟`;
}
---

<Layout
  title={`${article.title} · 博客`}
  description={article.excerpt}
  ogImage={`/og/${article.slug}.png`}
  headings={extractedHeadings}
  showToc={true}
  pageType="article"
  publishedTime={new Date(article.created).toISOString()}
  articleTag={article.tag}
>
  <a href="/articles" class="back mono">&lt; 返回博客列表</a>

  <article class="article">
    <header class="article-head">
      {article.tag && (
        <span class="tag">
          {article.emoji ? `${article.emoji} ` : ''}{article.tag}
        </span>
      )}
      <h1 class="title">{article.title}</h1>
      <div class="meta mono">
        <span>{fmtDate(article.created)}</span>
        <span class="sep">·</span>
        <span>{readingTime(article.content)}</span>
      </div>
    </header>

    <div class="article-body">
      <div class="prose" set:html={parsedContent} />
    </div>

    <footer class="share">
      <span class="share-label mono">SHARE</span>
      <div class="share-actions">
        <a
          class="share-btn x"
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="分享到 X (Twitter)"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817-5.97 6.817H1.67l7.73-8.835L1.25 2.25h6.83l4.713 6.231zM17.083 19.77h1.833L7.084 4.126H5.117z"/>
          </svg>
          X
        </a>
        <a
          class="share-btn hn"
          href={`https://news.ycombinator.com/submitlink?u=${encodeURIComponent(Astro.url.href)}&t=${encodeURIComponent(article.title)}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="分享到 Hacker News"
        >
          <span class="hn-mark">Y</span>
          HN
        </a>
        <a
          class="share-btn linkedin"
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="分享到 LinkedIn"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.59 0 4.25 2.36 4.25 5.43v6.31zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
          </svg>
          LinkedIn
        </a>
        <button class="share-btn copy" type="button" data-copy-url={Astro.url.href} aria-label="复制文章链接">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span class="copy-text">复制链接</span>
        </button>
      </div>
    </footer>
  </article>

  {(prevArticle || nextArticle) && (
    <nav class="adjacent-nav">
      {prevArticle ? (
        <a href={`/articles/${prevArticle.slug}`} class="adjacent-link prev">
          <span class="adjacent-label mono">← 上一篇</span>
          <span class="adjacent-title">{prevArticle.title}</span>
        </a>
      ) : <span class="adjacent-spacer" />}
      {nextArticle ? (
        <a href={`/articles/${nextArticle.slug}`} class="adjacent-link next">
          <span class="adjacent-label mono">下一篇 →</span>
          <span class="adjacent-title">{nextArticle.title}</span>
        </a>
      ) : <span class="adjacent-spacer" />}
    </nav>
  )}

  {relatedArticles.length > 0 && (
    <section class="related" aria-label="相关文章">
      <header class="related-head">
        <span class="related-kicker mono">RELATED</span>
        <h2 class="related-title">相关阅读</h2>
      </header>
      <div class="related-grid">
        {relatedArticles.map((r) => (
          <a href={`/articles/${r.slug}`} class="related-card">
            {r.tag && (
              <span class="related-tag">{r.emoji ? `${r.emoji} ` : ''}{r.tag}</span>
            )}
            <h3 class="related-card-title">{r.title}</h3>
            <p class="related-excerpt">{r.excerpt}</p>
            <span class="related-date mono">{fmtDate(r.created)}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <style>
    /* --- 返回链接 --- */
    .back {
      display: inline-block;
      margin-bottom: 20px;
      color: var(--surface-link);
      text-decoration: none;
      font-size: 13px;
    }
    .back:hover { text-decoration: underline; }
    .mono { font-family: var(--font-mono); }

    /* --- 整篇外卡 --- */
    .article {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: var(--card-shadow);
      color: var(--card-fg);
      border-radius: 22px;
      overflow: hidden;
    }

    /* --- 文章头分区（带顶部彩条） --- */
    .article-head {
      position: relative;
      padding: 36px 36px 24px;
      border-bottom: 1px solid var(--prose-hr);
      background: linear-gradient(
        180deg,
        color-mix(in oklab, var(--surface-link) 4%, transparent) 0%,
        transparent 100%
      );
    }
    .article-head::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 4px;
      background: linear-gradient(
        90deg,
        var(--surface-link),
        color-mix(in oklab, var(--surface-link) 30%, transparent)
      );
    }

    /* --- 正文分区 --- */
    .article-body {
      padding: 28px 36px 40px;
    }
    .tag {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      background: var(--prose-tag-bg);
      color: var(--prose-tag-fg);
    }
    .title {
      font-family: var(--font-display);
      font-size: clamp(26px, 4vw, 38px);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.25;
      margin: 14px 0 10px;
      color: var(--surface-fg);
    }
    .meta {
      display: flex;
      align-items: center;
      gap: 0;
      font-size: 12px;
      color: var(--surface-faint);
      letter-spacing: 0.04em;
    }
    .sep { margin: 0 8px; opacity: 0.5; }

    /* --- prose 主体 --- */
    .prose {
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.78;
      color: var(--prose-fg);
    }
    .prose :global(p) { margin: 18px 0; }

    .prose :global(h1),
    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4) {
      font-family: var(--font-display);
      font-weight: 700;
      letter-spacing: -0.015em;
      color: var(--surface-fg);
      margin: 36px 0 14px;
      line-height: 1.3;
    }
    .prose :global(h1) { font-size: 1.7em; }
    .prose :global(h2) {
      font-size: 1.42em;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--prose-hr);
    }
    .prose :global(h3) { font-size: 1.2em; }
    .prose :global(h4) { font-size: 1.05em; }

    .prose :global(a) {
      color: var(--prose-link);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
    }
    .prose :global(a:hover) { text-decoration-thickness: 2px; }

    .prose :global(strong) { color: var(--surface-fg); font-weight: 700; }
    .prose :global(em) { color: var(--surface-fg); }

    .prose :global(ul),
    .prose :global(ol) {
      margin: 18px 0;
      padding-left: 28px;
    }
    .prose :global(li) { margin: 6px 0; }
    .prose :global(li::marker) { color: var(--surface-faint); }

    /* 内联 code */
    .prose :global(code) {
      font-family: var(--font-mono);
      font-size: 0.88em;
      background: var(--prose-code-bg);
      color: var(--prose-code-fg);
      padding: 2px 6px;
      border-radius: 5px;
    }

    /* 代码块 */
    .prose :global(pre) {
      background: var(--prose-pre-bg);
      color: var(--prose-pre-fg);
      padding: 16px 18px;
      border-radius: 12px;
      overflow-x: auto;
      font-size: 13.5px;
      line-height: 1.6;
      margin: 22px 0;
      border: 1px solid var(--card-border);
    }
    .prose :global(pre code) {
      background: transparent;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    /* 引用 */
    .prose :global(blockquote) {
      border-left: 4px solid var(--prose-quote-border);
      padding: 8px 18px;
      margin: 22px 0;
      color: var(--prose-quote-fg);
      background: var(--prose-quote-bg);
      border-radius: 0 8px 8px 0;
    }
    .prose :global(blockquote p) { margin: 6px 0; }

    /* 分隔线 */
    .prose :global(hr) {
      border: none;
      border-top: 1px solid var(--prose-hr);
      margin: 36px 0;
    }

    /* 表格 */
    .prose :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 22px 0;
      font-size: 14px;
    }
    .prose :global(th),
    .prose :global(td) {
      padding: 10px 12px;
      border-bottom: 1px solid var(--prose-hr);
      text-align: left;
    }
    .prose :global(th) {
      font-weight: 700;
      color: var(--surface-fg);
      background: var(--prose-code-bg);
    }

    /* 图片 */
    .prose :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 12px;
      margin: 22px 0;
      border: 1px solid var(--card-border);
    }

    /* magazine 主题 — 衬线大标题 + 去圆角 */
    html[data-theme="magazine"] .article,
    html[data-theme="magazine"] .tag { border-radius: 0; }
    html[data-theme="magazine"] .title { text-transform: uppercase; letter-spacing: 0.01em; }
    html[data-theme="magazine"] .article-head::before { background: #0A0A0A; height: 6px; }
    html[data-theme="magazine"] .prose :global(pre),
    html[data-theme="magazine"] .prose :global(img),
    html[data-theme="magazine"] .prose :global(blockquote) { border-radius: 0; }
    html[data-theme="magazine"] .prose :global(blockquote) {
      border: 2px solid #0A0A0A;
      border-left-width: 6px;
    }

    /* 移动端缩小内边距 */
    @media (max-width: 720px) {
      .article-head { padding: 24px 20px 18px; }
      .article-body { padding: 22px 20px 28px; }
    }

    /* paper 主题 — 段首缩进感（首段不缩进）*/
    html[data-theme="paper"] .prose :global(p + p) { text-indent: 1.6em; }

    /* terminal 主题 — pre 加发光感 */
    html[data-theme="terminal"] .prose :global(pre) {
      border: 1px solid rgba(60, 255, 138, 0.25);
      box-shadow: inset 0 0 24px rgba(60, 255, 138, 0.05);
    }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      const btn = document.querySelector<HTMLButtonElement>('.share-btn.copy');
      if (!btn) return;
      const url = btn.dataset.copyUrl || location.href;
      const label = btn.querySelector<HTMLElement>('.copy-text');
      const original = label?.textContent ?? '复制链接';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url);
          btn.classList.add('copied');
          if (label) label.textContent = '已复制';
          setTimeout(() => {
            btn.classList.remove('copied');
            if (label) label.textContent = original;
          }, 1500);
        } catch {
          if (label) label.textContent = '复制失败';
        }
      });
    });
  </script>

  <style>
    /* --- 上下篇导航 --- */
    .adjacent-nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-top: 32px;
    }
    .adjacent-link {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 20px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 14px;
      text-decoration: none;
      color: var(--card-fg);
      box-shadow: var(--card-shadow);
      transition: transform 220ms cubic-bezier(.2,.8,.2,1), box-shadow 220ms;
    }
    .adjacent-link:hover {
      transform: translateY(-2px);
      box-shadow: var(--note-shadow-hover);
    }
    .adjacent-link.next { text-align: right; align-items: flex-end; }
    .adjacent-label {
      font-size: 11px;
      color: var(--surface-link);
      letter-spacing: 0.04em;
    }
    .adjacent-title {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 600;
      line-height: 1.4;
      color: var(--surface-fg);
    }
    .adjacent-spacer { display: none; }
    @media (max-width: 640px) {
      .adjacent-nav { grid-template-columns: 1fr; }
    }

    /* --- 相关文章 --- */
    .related {
      margin-top: 40px;
    }
    .related-head {
      margin-bottom: 18px;
    }
    .related-kicker {
      font-size: 11px;
      color: var(--surface-faint);
      letter-spacing: 0.08em;
    }
    .related-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.01em;
      margin: 4px 0 0;
      color: var(--surface-fg);
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }
    .related-card {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 18px 20px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 14px;
      box-shadow: var(--card-shadow);
      text-decoration: none;
      color: var(--card-fg);
      transition: transform 220ms cubic-bezier(.2,.8,.2,1), box-shadow 220ms;
    }
    .related-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--note-shadow-hover);
    }
    .related-tag {
      display: inline-block;
      align-self: flex-start;
      padding: 3px 9px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.04em;
      background: var(--prose-tag-bg);
      color: var(--prose-tag-fg);
    }
    .related-card-title {
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 700;
      line-height: 1.4;
      margin: 0;
      color: var(--surface-fg);
    }
    .related-excerpt {
      font-size: 12.5px;
      color: var(--surface-muted);
      line-height: 1.6;
      margin: 0;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .related-date {
      font-size: 10.5px;
      color: var(--surface-faint);
      letter-spacing: 0.02em;
    }
    html[data-theme="magazine"] .related-card,
    html[data-theme="magazine"] .related-tag { border-radius: 0; }
    html[data-theme="magazine"] .related-card-title {
      text-transform: uppercase;
      letter-spacing: 0.01em;
    }

    /* --- 分享栏 --- */
    .share {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      margin: 28px 36px 0;
      padding: 18px 0 4px;
      border-top: 1px solid var(--prose-hr);
    }
    .share-label {
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--surface-faint);
    }
    .share-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-decoration: none;
      color: var(--surface-fg);
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      cursor: pointer;
      font-family: inherit;
      transition: transform 180ms, box-shadow 180ms, background 180ms;
    }
    .share-btn:hover {
      transform: translateY(-1px);
      box-shadow: var(--card-shadow);
    }
    .share-btn.copy.copied {
      background: var(--prose-tag-bg);
      color: var(--prose-tag-fg);
    }
    .hn-mark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 14px;
      height: 14px;
      border-radius: 2px;
      background: #ff6600;
      color: #fff;
      font-weight: 800;
      font-size: 10px;
    }
    html[data-theme="magazine"] .share-btn { border-radius: 0; }
    @media (max-width: 720px) {
      .share { margin: 24px 20px 0; }
    }
  </style>
</Layout>
