---
/**
 * 全站悬浮主题切换器
 *
 * 现阶段：跳转到对应的 /prototypes/<slug>（供视觉对比）
 * 整合后（P-Theme 完成）：向当前路径 push 查询参数或写 cookie，
 * 服务端根据 cookie 重渲染，配合 View Transitions 平滑切换
 */
import { listThemes, DEFAULT_THEME, type ThemeSlug } from '../lib/theme';

interface Props {
  /** 当前激活主题（用于高亮） */
  active?: ThemeSlug;
  /** 切换目标基路径；默认 /prototypes/ 原型模式；整合后传 '/' */
  basePath?: string;
}

const { active = DEFAULT_THEME, basePath = '/prototypes/' } = Astro.props as Props;
const themes = listThemes();
---

<div class="theme-switcher" data-active={active}>
  <button class="ts-toggle" type="button" aria-label="切换主题" aria-expanded="false">
    <span class="ts-toggle-icon">🎨</span>
    <span class="ts-toggle-label">主题</span>
    <span class="ts-toggle-active-dot" style={`background: ${themes.find(t => t.slug === active)?.color};`}></span>
  </button>

  <div class="ts-panel" role="menu">
    <div class="ts-heading">
      <span>选择风格</span>
      <span class="ts-kbd">esc</span>
    </div>
    {themes.map(t => (
      <a
        href={`${basePath}${t.slug}`}
        class:list={['ts-opt', { active: active === t.slug }]}
        data-slug={t.slug}
        role="menuitem"
      >
        <span class="ts-dot" style={`background: ${t.color}; box-shadow: 0 0 10px ${t.color}aa;`}></span>
        <span class="ts-opt-icon">{t.icon}</span>
        <span class="ts-opt-body">
          <span class="ts-opt-name">{t.name}</span>
          <span class="ts-opt-tag">{t.tagline}</span>
        </span>
        {active === t.slug && <span class="ts-check">✓</span>}
      </a>
    ))}
    <div class="ts-footer">
      <span class="ts-hint">提示：选择会记住在 cookie 里</span>
    </div>
  </div>
</div>

<style is:global>
  .theme-switcher {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 9999;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color-scheme: dark;
  }
  .ts-toggle {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 16px 10px 14px;
    border-radius: 999px;
    background: rgba(10, 10, 14, 0.82);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    color: white;
    border: 1px solid rgba(255,255,255,0.12);
    cursor: pointer;
    font-size: 13px; font-weight: 500; font-family: inherit;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    transition: transform 260ms cubic-bezier(.2,.7,.2,1), box-shadow 260ms;
  }
  .ts-toggle:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 12px 32px rgba(0,0,0,0.35); }
  .ts-toggle-icon { font-size: 16px; }
  .ts-toggle-active-dot {
    width: 8px; height: 8px; border-radius: 999px;
    box-shadow: 0 0 8px currentColor;
    margin-left: 2px;
  }

  .ts-panel {
    position: absolute;
    right: 0; bottom: calc(100% + 10px);
    width: 260px;
    background: rgba(10, 10, 14, 0.96);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 6px;
    opacity: 0;
    transform: translateY(12px) scale(0.94);
    transform-origin: bottom right;
    pointer-events: none;
    transition: opacity 260ms cubic-bezier(.2,.7,.2,1), transform 260ms cubic-bezier(.2,.7,.2,1);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 2px 8px rgba(0,0,0,0.3);
  }
  .theme-switcher.open .ts-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .ts-heading {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 14px 8px;
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    font-weight: 600;
  }
  .ts-kbd {
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 10px;
    background: rgba(255,255,255,0.08);
    padding: 2px 6px; border-radius: 4px;
    letter-spacing: 0;
    text-transform: lowercase;
  }
  .ts-opt {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    color: rgba(255,255,255,0.88);
    text-decoration: none;
    transition: background 160ms, transform 180ms cubic-bezier(.2,.7,.2,1);
  }
  .ts-opt:hover {
    background: rgba(255,255,255,0.07);
    transform: translateX(3px);
  }
  .ts-opt.active {
    background: linear-gradient(90deg, rgba(168,230,207,0.14), rgba(255,255,255,0.04));
  }
  .ts-dot {
    width: 9px; height: 9px; border-radius: 999px;
    flex-shrink: 0;
  }
  .ts-opt-icon { font-size: 16px; }
  .ts-opt-body { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
  .ts-opt-name { font-size: 13px; font-weight: 600; line-height: 1.2; }
  .ts-opt-tag { font-size: 11px; color: rgba(255,255,255,0.5); line-height: 1.3; }
  .ts-check {
    color: #A8E6CF;
    font-weight: 700;
    font-size: 14px;
    text-shadow: 0 0 8px rgba(168,230,207,0.6);
  }

  .ts-footer {
    padding: 10px 14px 8px;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: 4px;
  }
  .ts-hint {
    font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .theme-switcher { right: 14px; bottom: 14px; }
    .ts-panel { width: calc(100vw - 28px); max-width: 280px; }
    .ts-toggle-label { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const switcher = document.querySelector<HTMLElement>('.theme-switcher');
    if (!switcher) return;
    const toggle = switcher.querySelector<HTMLButtonElement>('.ts-toggle');

    const setOpen = (open: boolean) => {
      switcher.classList.toggle('open', open);
      toggle?.setAttribute('aria-expanded', String(open));
    };

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!switcher.classList.contains('open'));
    });

    document.addEventListener('click', (e) => {
      if (!switcher.contains(e.target as Node)) setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    // 写入 cookie（供未来真正整合使用）
    switcher.querySelectorAll<HTMLAnchorElement>('.ts-opt').forEach((a) => {
      a.addEventListener('click', () => {
        const slug = a.dataset.slug;
        if (slug) {
          document.cookie = `site_theme=${slug}; max-age=31536000; path=/; SameSite=Lax`;
        }
      });
    });
  });
</script>
