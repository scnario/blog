---
/**
 * 音乐播放器 — PB settings 驱动
 */
import { getSettings } from '../lib/queries';

const settings = await getSettings();
const musicUrl = settings.music_url || 'https://cdn.pixabay.com/audio/2022/05/27/audio_1808fbf07a.mp3';
const musicTitle = settings.music_title || '未配置音乐';
const musicArtist = settings.music_artist || '在控制台 · 站点设置 中配置';
const hasMusic = !!settings.music_url;
---

{hasMusic ? (
  <div class="glass-panel fixed bottom-6 left-6 z-[60] flex items-center gap-3 p-2 pr-4 rounded-full transition-transform hover:scale-105">
    <div class="w-10 h-10 rounded-full border-2 border-gray-600/50 overflow-hidden animate-[spin_4s_linear_infinite]" id="record-spin" style="animation-play-state: paused;">
      <img src="https://images.unsplash.com/photo-1614680376593-902f74cf0d41?q=80&w=200&auto=format&fit=crop" class="w-full h-full object-cover" alt="封面"/>
    </div>
    <div class="flex flex-col max-w-[120px] cursor-default">
      <span class="text-xs font-bold text-[#f8fafc] truncate">{musicTitle}</span>
      <span class="text-[10px] text-[#a1a1aa] truncate">{musicArtist}</span>
    </div>
    <button id="play-btn" class="ml-2 w-8 h-8 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer border-none">
      <svg id="play-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      <svg id="pause-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
    <audio id="bg-music" src={musicUrl} loop></audio>
  </div>
) : null}

<script>
  const audio = document.getElementById('bg-music') as HTMLAudioElement | null;
  const playBtn = document.getElementById('play-btn');
  const playIcon = document.getElementById('play-icon');
  const pauseIcon = document.getElementById('pause-icon');
  const recordSpin = document.getElementById('record-spin');

  playBtn?.addEventListener('click', () => {
    if (!audio || !recordSpin || !playIcon || !pauseIcon) return;
    if (audio.paused) {
      audio.play(); playIcon.classList.add('hidden'); pauseIcon.classList.remove('hidden'); recordSpin.style.animationPlayState = 'running';
    } else {
      audio.pause(); pauseIcon.classList.add('hidden'); playIcon.classList.remove('hidden'); recordSpin.style.animationPlayState = 'paused';
    }
  });
</script>
