---
const { title } = Astro.props;
---
<header class="glass-panel mb-10 p-8 md:p-10 rounded-2xl relative overflow-hidden">
  <div class="absolute top-[-50%] left-[-10%] w-64 h-64 bg-cyan-500/20 rounded-full blur-[80px] pointer-events-none"></div>
  <div class="relative z-10">
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class="px-3 py-1 text-xs rounded-md bg-white/10 text-white font-medium shadow-inner">原创</span>
      <span class="px-3 py-1 text-xs rounded-md bg-[#10b981]/20 text-[#10b981] font-medium border border-[#10b981]/30">Tech</span>
      <span class="text-xs text-gray-400 tracking-wide">#Docker #Linux #Debian #DevOps</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-8 leading-snug tracking-wide">{title}</h1>
    <div class="flex flex-wrap items-center gap-6 text-xs text-gray-400 font-medium">
      <span class="flex items-center gap-1.5"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> Created 2026-03-15</span>
      <span class="flex items-center gap-1.5"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> Post View: 193</span>
      <span class="flex items-center gap-1.5"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg> 📍 日本</span>
    </div>
  </div>
</header>