<div class="glass-panel relative w-full h-[320px] rounded-2xl overflow-hidden flex flex-col justify-between p-5 border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.5)]">
  <div class="absolute inset-0 bg-gradient-to-br from-[#d4a373] via-[#3b82f6] to-[#0ea5e9] opacity-80 z-0"></div>
  <div class="absolute inset-0 bg-black/10 z-0"></div>

  <div class="relative z-10 flex justify-center mt-2">
    <span class="bg-white/20 backdrop-blur-md text-white/90 text-[11px] px-4 py-1.5 rounded-full tracking-widest border border-white/20 shadow-sm">
      集中精力，攻克难关
    </span>
  </div>

  <div class="relative z-10 flex justify-center mt-[-20px]">
    <div class="relative">
      <div class="w-24 h-24 rounded-full border-[3px] border-white shadow-lg bg-cover bg-center transition-all duration-300" 
           style="background-image: var(--avatar-main, url('https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=200&auto=format&fit=crop'))">
      </div>
      <div class="absolute bottom-0 right-0 w-8 h-8 rounded-full border-2 border-white object-cover shadow-sm bg-cover bg-center transition-all duration-300" 
           style="background-image: var(--avatar-sub, url('https://images.unsplash.com/photo-1517841905240-472988babdf9?q=80&w=100&auto=format&fit=crop'))">
