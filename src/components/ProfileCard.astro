---
/**
 * 个人资料卡 — 主题感知 + PB 驱动
 *
 * 数据：getSettings() 拉取 nickname / bio / social_github / avatar_*
 * 配色：全部走 --card-* / --surface-* / --prose-tag-* token；
 *      顶部彩条用 `--surface-link` 渐变，所以 5 套主题都自然契合。
 */
import { getSettings } from '../lib/queries';

const settings = await getSettings();

const nickname = settings.nickname || 'scnario';
const tagline  = settings.bio || settings.tagline || 'Day by day, life by life';
const github   = settings.social_github || 'https://github.com/scnario/blog';
const hasGithub = !!github;

const avatarMain = settings.avatar_main
  || 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=200&auto=format&fit=crop';
const avatarSub  = settings.avatar_sub
  || 'https://images.unsplash.com/photo-1517841905240-472988babdf9?q=80&w=100&auto=format&fit=crop';
---

<div class="profile">
  <div class="cover"></div>

  <div class="badge-wrap">
    <span class="badge">集中精力，攻克难关</span>
  </div>

  <div class="avatar-wrap">
    <div class="avatar-main" style={`background-image: url('${avatarMain}')`}></div>
    <div class="avatar-sub" style={`background-image: url('${avatarSub}')`}></div>
  </div>

  <div class="bottom">
    <div class="text">
      <h3 class="nickname">{nickname}</h3>
      <p class="tagline">{tagline}</p>
    </div>

    <div class="actions">
      <a href="/console" class="action-btn" title="控制台" aria-label="控制台">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
      </a>
      <a
        href={hasGithub ? github : '#'}
        target={hasGithub ? '_blank' : undefined}
        rel={hasGithub ? 'noopener noreferrer' : undefined}
        class={`action-btn ${hasGithub ? '' : 'is-disabled'}`}
        aria-disabled={hasGithub ? 'false' : 'true'}
        title={hasGithub ? 'GitHub' : 'GitHub（未配置）'}
        aria-label="GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>
  </div>
</div>

<style>
  .profile {
    position: relative;
    width: 100%;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    color: var(--card-fg);
    border-radius: 18px;
    padding: 0 18px 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* 顶部彩条 — 用主题 link 色做渐变，5 套主题都跟着变 */
  .cover {
    height: 70px;
    margin: 0 -18px 0;
    background: linear-gradient(
      135deg,
      var(--surface-link),
      color-mix(in oklab, var(--surface-link) 35%, var(--card-bg))
    );
  }

  .badge-wrap {
    display: flex;
    justify-content: center;
    margin-top: -14px;
  }
  .badge {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 5px 14px;
    border-radius: 999px;
    background: var(--prose-tag-bg);
    color: var(--prose-tag-fg);
    border: 1px solid var(--card-border);
  }

  .avatar-wrap {
    position: relative;
    width: 96px;
    height: 96px;
    margin: -10px auto 4px;
  }
  .avatar-main {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 3px solid var(--card-bg);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    background-size: cover;
    background-position: center;
  }
  .avatar-sub {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--card-bg);
    background-size: cover;
    background-position: center;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  .bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 10px;
    padding-top: 4px;
  }

  .text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .nickname {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--surface-fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tagline {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--surface-muted);
    margin: 0;
    line-height: 1.45;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .actions { display: flex; gap: 8px; flex-shrink: 0; }
  .action-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--card-border);
    color: var(--surface-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 180ms, border-color 180ms, background 180ms, transform 180ms;
  }
  .action-btn:hover {
    color: var(--surface-link);
    border-color: var(--surface-link);
    background: color-mix(in oklab, var(--surface-link) 10%, transparent);
    transform: translateY(-1px);
  }
  .action-btn.is-disabled {
    pointer-events: none;
    opacity: 0.4;
  }

  /* magazine 主题 — 整卡去圆角 */
  html[data-theme="magazine"] .profile,
  html[data-theme="magazine"] .badge { border-radius: 0; }
</style>
